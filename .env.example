# ─────────────────────────────────────────────────────────────────────────────
# Contract Portal Automation — environment configuration
#
# Local runs:  copy this file to `.env` and fill in the real values.
#              `.env` is git-ignored and must NEVER be committed.
# CI runs:     these are injected from GitHub Secrets (see .github/workflows).
# ─────────────────────────────────────────────────────────────────────────────

# Application under test
BASE_URL=https://uat.contracts.com.sa

# UI language the suite drives the app in: en | ar
DEFAULT_LANGUAGE=en

# ── Admin role (Company Login form: email + password) ────────────────────────
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_OTP=

# ── Company Admin role (Company Login form: email + password) ────────────────
COMPANY_ADMIN_USERNAME=
COMPANY_ADMIN_PASSWORD=
COMPANY_ADMIN_OTP=

# ── Individual Portal role (Individual Login form: national ID + password) ───
INDIVIDUAL_USERNAME=
INDIVIDUAL_PASSWORD=
INDIVIDUAL_OTP=

# ── Self-healing layer (Phase 4) ─────────────────────────────────────────────
# Enable the locator-fallback healing wrapper.
HEAL_ENABLED=true
# Minimum fingerprint match score (0..1) for a healed locator to be accepted.
HEAL_CONFIDENCE_THRESHOLD=0.7
